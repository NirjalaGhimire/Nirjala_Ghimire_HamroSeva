# Copy to assets/.env and set your Web OAuth client ID from Google Cloud Console.
GOOGLE_WEB_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Physical phone + Wi‑Fi (same LAN as your PC): your PC's IPv4, e.g. 192.168.1.5
# Omit if you use USB + adb reverse tcp:8000 tcp:8000 instead.
# BACKEND_HOST=192.168.1.5
