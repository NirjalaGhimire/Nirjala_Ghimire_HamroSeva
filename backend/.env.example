# Copy to .env and set your key. Do not commit .env.
# Get key: Google Cloud Console → APIs & Services → Credentials → Create API key
# Enable: Maps SDK for Android, Places API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Password reset emails (SMTP only). See docs/GMAIL_SMTP_PASSWORD_RESET.md
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your_google_app_password
# DEFAULT_FROM_EMAIL=you@gmail.com

# --- OpenRouter (AI assistant: POST /api/ai/query/) ---
# Get a key at https://openrouter.ai — never commit real keys; use backend/.env only.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution for OpenRouter dashboard:
# OPENROUTER_SITE_URL=http://localhost:8000
# OPENROUTER_APP_TITLE=Hamro Sewa
